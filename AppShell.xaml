<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Raymond_Sean_RushHour.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Raymond_Sean_RushHour"
    Title="Rush Hour">

    <TabBar>
        <ShellContent
            Title="Game"
            ContentTemplate="{DataTemplate local:GamePage}"
            Route="GamePage" />
        
        <ShellContent
            Title="Scores"
            ContentTemplate="{DataTemplate local:ScorePage}"
            Route="ScorePage" />
        
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
