<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Raymond_Sean_RushHour.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Raymond_Sean_RushHour"
    Title="Rush Hour"
    BackgroundColor="#000000"
    ForegroundColor="White">

    <FlyoutItem Title="RUSH HOUR">
        <ShellContent
            Title="Rush Hour"
            ContentTemplate="{DataTemplate local:GamePage}"
            Route="GamePage" />
    </FlyoutItem>

    <FlyoutItem Title="Scores">
        <ShellContent
            Title="Scores"
            ContentTemplate="{DataTemplate local:ScorePage}"
            Route="ScorePage" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </FlyoutItem>

</Shell>
