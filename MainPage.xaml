<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Raymond_Sean_RushHour.MainPage"
             Title="Rush Hour"
             BackgroundColor="#87CEEB">

    <VerticalStackLayout
        Padding="30"
        Spacing="30"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <!-- Game Title -->
        <Label
            Text="RUSH HOUR"
            FontSize="48"
            FontAttributes="Bold"
            TextColor="White"
            HorizontalTextAlignment="Center"
            Margin="0,0,0,20" />

        <Label
            Text="Endless Driving Game"
            FontSize="18"
            TextColor="White"
            HorizontalTextAlignment="Center"
            Margin="0,0,0,30" />

        <!-- Play Button -->
        <Button
            Text="Play Game"
            FontSize="18"
            FontAttributes="Bold"
            Padding="20,15"
            CornerRadius="10"
            BackgroundColor="#FF6B6B"
            TextColor="White"
            Clicked="OnPlayClicked" />

        <!-- Stats -->
        <Frame CornerRadius="10" BorderColor="#4ECDC4" Padding="20" HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <Label Text="Your Stats" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                <Label x:Name="HighScoreLabel" Text="High Score: 0" FontSize="16" TextColor="White"/>
                <Label x:Name="GamesPlayedLabel" Text="Games Played: 0" FontSize="16" TextColor="White"/>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>

</ContentPage>
